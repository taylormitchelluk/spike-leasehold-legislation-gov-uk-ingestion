{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "spike-leasehold-legislation-gov-uk-ingestion",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-21",

  "r2_buckets": [
    {
      "binding": "LEGISLATION_BUCKET",
      "bucket_name": "spike-leasehold-legislation"
    }
  ],

  // "triggers": {
  //   // At 03:15 UTC every Sunday.
  //   "crons": ["15 3 * * 0"]
  // },

  "observability": {
    "enabled": true
  }
}
